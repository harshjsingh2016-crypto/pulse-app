# ─── Secrets — NEVER commit real API keys ────────────────────────────────────
# functions/.env holds Anthropic / OpenAI / Resend keys + the reviewer code.
functions/.env
functions/.env.*
!functions/.env.example
# Local env files (Firebase config for local dev, etc.)
.env
*.local
app/.env.local
# app/.env.production is kept OUT of the repo by choice. It holds only the PUBLIC
# EXPO_PUBLIC_FIREBASE_* web config, but builds must still receive it — supply it to
# EAS builds via EAS environment variables (eas env:create) instead of this file.
app/.env.production

# ─── Dependencies (huge, restorable via npm install) ─────────────────────────
node_modules/

# ─── Build output / generated ────────────────────────────────────────────────
app/dist/
app/web-build/
functions/lib/
expo-env.d.ts
*.tsbuildinfo

# ─── Expo / React Native ─────────────────────────────────────────────────────
.expo/
.kotlin/
.metro-health-check*
# Generated native projects (regenerated by prebuild/EAS)
/app/ios
/app/android

# ─── Firebase local artifacts ────────────────────────────────────────────────
.firebase/
firebase-debug.log
firestore-debug.log
*-debug.log

# ─── Signing material — must never be committed ──────────────────────────────
*.jks
*.p8
*.p12
*.key
*.pem
*.mobileprovision

# ─── Editor / OS / tooling ───────────────────────────────────────────────────
.DS_Store
.claude/
npm-debug.*
yarn-debug.*
yarn-error.*
*.orig.*
