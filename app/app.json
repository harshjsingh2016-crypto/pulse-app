{
  "expo": {
    "name": "Pulse",
    "slug": "pulse",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "pulse",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "in.pulseaiapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1C1612",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "in.pulseaiapp",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "pulse"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "versionCode": 6
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Pulse to use the microphone for voice input in chat."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#B85450"
        }
      ],
      [
        "@sentry/react-native",
        {
          "organization": "pulse-ue",
          "project": "react-native",
          "url": "https://de.sentry.io/"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1C1612",
          "image": "./assets/splash-icon.png",
          "imageWidth": 300,
          "dark": {
            "backgroundColor": "#1C1612",
            "image": "./assets/splash-icon.png"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1598265a-cecd-4471-8ebb-ed2a48ec14f7"
      }
    },
    "owner": "harshjsingh"
  }
}
