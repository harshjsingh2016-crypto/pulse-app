rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // All user data lives under /users/{userId}/
    // Only the authenticated user can read/write their own documents
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Enforce one recurring completion per task per date
    match /users/{userId}/recurring_completions/{completionId} {
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && !exists(/databases/$(database)/documents/users/$(userId)/recurring_completions/$(request.resource.data.task_id + '_' + request.resource.data.date));
    }
  }
}
